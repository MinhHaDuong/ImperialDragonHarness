# Track only the harness — ignore everything else
*

# Harness components
!.gitignore
!README.md
!STATE.md
!CLAUDE.md
!.github/
!.github/**
!skills/
!skills/**
!scripts/
!scripts/**
!bin/
!bin/**
!commands/
!commands/**
!docs/
!docs/**
!tickets/
!tickets/**
# Exclude compiled Go binaries from ticket tools
tickets/tools/go/git-erg
tickets/tools/go/erg
tickets/tools/go/*.test

# Python bytecode
__pycache__/
*.pyc

# settings.json: universal config (hooks, effortLevel, universal permissions) — tracked
# settings.local.json: machine-specific permissions — gitignored
!settings.json
!settings.template.json
